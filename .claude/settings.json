{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo clippy --message-format=json > *)",
      "Bash(cargo fmt:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "Bash(cargo llvm-cov:*)",
      "Bash(docker info:*)",
      "Bash(docker run:*)",
      "Bash(sonar-scanner:*)",
      "Bash(docker compose:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git add:*)",
      "Bash(git worktree:*)",
      "Bash(git commit:*)",
      "Bash(git ls-files:*)",
      "Bash(cargo xtask:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(.env*)",
      "Read(**/.env*)"
    ]
  }
}